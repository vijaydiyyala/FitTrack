# FitTrack environment variables.
# Copy this file to ".env" and fill in real values. The .env file is gitignored.
# All keys are EXPO_PUBLIC_* so they are inlined into the client bundle at build time.
# NOTE: EXPO_PUBLIC_* values are NOT secret — they ship in the app. Lock them down
# with Firebase Security Rules and API key restrictions (HTTP referrer / bundle id).

# --- Firebase (Project settings > General > Your apps > SDK setup) ---
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# --- Google Maps / Places (Google Cloud Console) ---
# Used both as the native Maps SDK key (via app.config.ts) and for Places REST calls.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- ExerciseDB (RapidAPI: https://rapidapi.com/justin-WFnsXH_t6/api/exercisedb) ---
EXPO_PUBLIC_EXERCISEDB_API_KEY=
EXPO_PUBLIC_EXERCISEDB_API_HOST=exercisedb.p.rapidapi.com
